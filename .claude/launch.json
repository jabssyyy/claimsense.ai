{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "frontend/node_modules/vite/bin/vite.js",
        "--port",
        "5173"
      ],
      "port": 5173
    }
  ]
}
